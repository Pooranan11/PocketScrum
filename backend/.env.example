# URL de connexion Redis
REDIS_URL=redis://localhost:6379

# Clé secrète pour la signature des tokens de session (HMAC-SHA256)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-moi-en-production-avec-une-valeur-aleatoire-securisee

# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173

# Environnement applicatif : development | production
APP_ENV=development

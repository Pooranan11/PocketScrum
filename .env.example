# ── Clé secrète HMAC (obligatoire en production) ──────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-moi-en-production

# ── Origines CORS autorisées ───────────────────────────────────────────────────
# Mettez l'URL publique de votre serveur (sans slash final)
# Format URL simple :
CORS_ORIGINS=http://votre-ip-ou-domaine
# Ou format JSON (plusieurs origines) :
# CORS_ORIGINS=["http://votre-ip","https://votre-domaine.com"]

# ── Environnement ──────────────────────────────────────────────────────────────
APP_ENV=production

# ── Rate limiting REST (requêtes / minute par IP) ─────────────────────────────
RATE_LIMIT_PER_MINUTE=60
